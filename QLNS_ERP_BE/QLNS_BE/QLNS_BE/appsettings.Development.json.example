# appsettings.Development.json - CẤU HÌNH MẪU
# Copy file này thành appsettings.Development.json và điền API key thật

{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "server=localhost;port=3306;database=qlns_erp;user=root;password=1234567;SslMode=None"
  },
  "Jwt": {
    "Issuer": "QLNS-ERP",
    "Audience": "QLNS-ERP",
    "SecretKey": "J7d9K8fN3xP2rQ9tV5mB2zW8uT4nA1yR6pL3fD9gH4cS2x",
    "AccessTokenMinutes": 60,
    "RefreshTokenDays": 7
  },
  "FaceRecognition": {
    "ConfidenceThreshold": 0.6,
    "MinQualityScore": 0.45,
    "MaxFacesPerEmployee": 3,
    "ImageMaxSizeMB": 5,
    "AllowedExtensions": [
      ".jpg",
      ".jpeg",
      ".png"
    ],
    "PythonApiUrl": ""
  },
  "Gemini": {
    "ApiKey": "PASTE_YOUR_GEMINI_API_KEY_HERE",
    "Model": "gemini-1.5-flash",
    "MaxTokens": 2048,
    "Temperature": 0.1
  },
  "WorkTime": {
    "Start": "08:00",
    "End": "17:00",
    "LateGraceMinutes": 0,
    "EarlyLeaveGraceMinutes": 0
  },
  "AllowedHosts": "*"
}
