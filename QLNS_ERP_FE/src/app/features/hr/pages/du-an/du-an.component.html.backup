<!-- src/app/features/du-an/pages/du-an-hr-acc/du-an-hr-acc.component.html -->

<div class="duan-page">
    <!-- HERO -->
    <div class="hero card border-0 shadow-sm mb-3">
        <div class="card-body d-flex flex-column flex-lg-row gap-3 align-items-lg-center justify-content-between">
            <div>
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-kanban fs-4"></i>
                    <h4 class="mb-0">Quản lý Dự án (HR_KETOAN)</h4>
                </div>
                <div class="text-muted mt-1">
                    Tạo / cập nhật / gửi duyệt dự án, quản lý thành viên, theo dõi trạng thái.
                </div>
            </div>

            <div class="d-flex flex-wrap gap-2">
                <button class="btn btn-primary" (click)="startCreate()" [disabled]="loading || saving">
                    <i class="bi bi-plus-circle me-1"></i> Tạo dự án
                </button>
                <button class="btn btn-outline-secondary" (click)="loadList()" [disabled]="loading || saving">
                    <i class="bi bi-arrow-clockwise me-1"></i> Refresh
                </button>
                <button class="btn btn-outline-dark" (click)="guiDuyet()" [disabled]="!canGuiDuyet() || saving">
                    <i class="bi bi-send me-1"></i> Gửi duyệt
                </button>
            </div>
        </div>
    </div>

    <!-- ERROR -->
    <div *ngIf="errorMsg" class="alert alert-danger">
        <i class="bi bi-exclamation-triangle me-1"></i>{{ errorMsg }}
    </div>

    <!-- KPI -->
    <div class="row g-3 mb-3">
        <div class="col-12">
            <div class="card border-0 shadow-sm kpi-chart-card">
                <div class="card-body">
                    <div
                        class="d-flex flex-column flex-lg-row align-items-start align-items-lg-center justify-content-between mb-3">
                        <div>
                            <h5 class="mb-1 fw-bold">
                                <i class="bi bi-bar-chart-line me-2"></i>Tổng quan dự án
                            </h5>
                            <div class="text-muted small">Phân bổ trạng thái dự án theo từng loại</div>
                        </div>
                        <div class="kpi-total-badge">
                            <span class="text-muted small">Tổng cộng</span>
                            <span class="total-value">{{ kpiTotal }}</span>
                        </div>
                    </div>

                    <div class="row g-3">
                        <!-- BAR CHART -->
                        <div class="col-12 col-lg-5">
                            <div class="bar-chart-container">
                                <div class="bar-item" [class.bar-loading]="loading">
                                    <div class="bar-header">
                                        <div class="bar-label">
                                            <i class="bi bi-circle-fill text-slate"></i>
                                            <span>Nháp</span>
                                        </div>
                                        <span class="bar-value">{{ kpiDraft }}</span>
                                    </div>
                                    <div class="bar-track">
                                        <div class="bar-fill bar-draft"
                                            [style.width.%]="kpiTotal > 0 ? (kpiDraft / kpiTotal * 100) : 0"></div>
                                    </div>
                                </div>

                                <div class="bar-item" [class.bar-loading]="loading">
                                    <div class="bar-header">
                                        <div class="bar-label">
                                            <i class="bi bi-circle-fill text-warning"></i>
                                            <span>Chờ duyệt</span>
                                        </div>
                                        <span class="bar-value">{{ kpiPending }}</span>
                                    </div>
                                    <div class="bar-track">
                                        <div class="bar-fill bar-pending"
                                            [style.width.%]="kpiTotal > 0 ? (kpiPending / kpiTotal * 100) : 0"></div>
                                    </div>
                                </div>

                                <div class="bar-item" [class.bar-loading]="loading">
                                    <div class="bar-header">
                                        <div class="bar-label">
                                            <i class="bi bi-circle-fill text-success"></i>
                                            <span>Đã duyệt</span>
                                        </div>
                                        <span class="bar-value">{{ kpiApproved }}</span>
                                    </div>
                                    <div class="bar-track">
                                        <div class="bar-fill bar-approved"
                                            [style.width.%]="kpiTotal > 0 ? (kpiApproved / kpiTotal * 100) : 0"></div>
                                    </div>
                                </div>

                                <div class="bar-item" [class.bar-loading]="loading">
                                    <div class="bar-header">
                                        <div class="bar-label">
                                            <i class="bi bi-circle-fill text-danger"></i>
                                            <span>Từ chối</span>
                                        </div>
                                        <span class="bar-value">{{ kpiRejected }}</span>
                                    </div>
                                    <div class="bar-track">
                                        <div class="bar-fill bar-rejected"
                                            [style.width.%]="kpiTotal > 0 ? (kpiRejected / kpiTotal * 100) : 0"></div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- KPI CARDS -->
                        <div class="col-12 col-lg-7">
                            <div class="row g-3">
                                <div class="col-6 col-md-3">
                                    <div class="kpi-mini kpi-draft">
                                        <div class="kpi-icon">
                                            <i class="bi bi-file-earmark-text"></i>
                                        </div>
                                        <div class="kpi-content">
                                            <div class="kpi-label">Nháp</div>
                                            <div class="kpi-value">{{ kpiDraft }}</div>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-6 col-md-3">
                                    <div class="kpi-mini kpi-pending">
                                        <div class="kpi-icon">
                                            <i class="bi bi-clock-history"></i>
                                        </div>
                                        <div class="kpi-content">
                                            <div class="kpi-label">Chờ duyệt</div>
                                            <div class="kpi-value">{{ kpiPending }}</div>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-6 col-md-3">
                                    <div class="kpi-mini kpi-approved">
                                        <div class="kpi-icon">
                                            <i class="bi bi-check-circle"></i>
                                        </div>
                                        <div class="kpi-content">
                                            <div class="kpi-label">Đã duyệt</div>
                                            <div class="kpi-value">{{ kpiApproved }}</div>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-6 col-md-3">
                                    <div class="kpi-mini kpi-rejected">
                                        <div class="kpi-icon">
                                            <i class="bi bi-x-circle"></i>
                                        </div>
                                        <div class="kpi-content">
                                            <div class="kpi-label">Từ chối</div>
                                            <div class="kpi-value">{{ kpiRejected }}</div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- PERCENTAGE SUMMARY -->
                            <div class="percentage-summary mt-3">
                                <div class="summary-item" *ngIf="kpiTotal > 0">
                                    <span class="text-muted small">Tỷ lệ hoàn thành:</span>
                                    <span class="fw-semibold text-success">{{ (kpiApproved / kpiTotal * 100).toFixed(1)
                                        }}%</span>
                                </div>
                                <div class="summary-item" *ngIf="kpiTotal > 0">
                                    <span class="text-muted small">Đang chờ xử lý:</span>
                                    <span class="fw-semibold text-warning">{{ ((kpiDraft + kpiPending) / kpiTotal *
                                        100).toFixed(1) }}%</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- MAIN -->
    <div class="row g-3">
        <!-- LEFT: LIST -->
        <div class="col-12 col-lg-7">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-0">
                    <div class="d-flex flex-column flex-md-row gap-2 justify-content-between">
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-search"></i></span>
                            <input type="text" class="form-control" placeholder="Tìm theo mã / tên / người phụ trách..."
                                [(ngModel)]="q" (input)="applyFilter()" />
                        </div>

                        <div class="d-flex gap-2">
                            <select class="form-select" [(ngModel)]="statusFilter" (change)="applyFilter()">
                                <option value="ALL">Tất cả trạng thái</option>
                                <option value="DANG_NHAP">Nháp</option>
                                <option value="CHO_DUYET_GIAM_DOC">Chờ duyệt giám đốc</option>
                                <option value="DA_DUYET">Đã duyệt</option>
                                <option value="TU_CHOI">Từ chối</option>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="card-body p-0">
                    <!-- SKELETON -->
                    <div *ngIf="loading" class="p-3">
                        <div class="placeholder-glow mb-2" *ngFor="let i of [1,2,3,4,5]">
                            <span class="placeholder col-12"></span>
                        </div>
                    </div>

                    <div *ngIf="!loading" class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th style="min-width: 120px;">Mã</th>
                                    <th style="min-width: 220px;">Tên dự án</th>
                                    <th style="min-width: 180px;">Phụ trách</th>
                                    <th style="min-width: 140px;">Trạng thái</th>
                                    <th class="text-end" style="min-width: 90px;">#</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr *ngFor="let x of filtered" [class.active-row]="x.id === selectedId"
                                    (click)="openDetail(x.id)">
                                    <td class="fw-semibold">{{ x.maDuAn }}</td>
                                    <td>
                                        <div class="fw-semibold">{{ x.tenDuAn }}</div>
                                        <div class="small text-muted">
                                            {{ x.ngayBatDau ? (x.ngayBatDau | date:'dd/MM/yyyy') : '—' }}
                                            →
                                            {{ x.ngayKetThuc ? (x.ngayKetThuc | date:'dd/MM/yyyy') : '—' }}
                                        </div>
                                    </td>
                                    <td>{{ x.tenNhanVienPhuTrach || '—' }}</td>
                                    <td><span class="badge" [ngClass]="badgeClass(x.trangThaiDuAn)">{{ x.trangThaiDuAn
                                            }}</span></td>
                                    <td class="text-end">
                                        <button class="btn btn-sm btn-outline-primary" type="button"
                                            (click)="$event.stopPropagation(); openDetail(x.id)">
                                            <i class="bi bi-eye"></i>
                                        </button>
                                    </td>
                                </tr>

                                <tr *ngIf="filtered.length === 0">
                                    <td colspan="5" class="text-center text-muted py-4">Không có dữ liệu</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- FORM (CREATE/EDIT) -->
            <div *ngIf="mode !== 'LIST'" class="card border-0 shadow-sm mt-3">
                <div class="card-header bg-white border-0 d-flex align-items-center justify-content-between">
                    <div class="fw-semibold">
                        <i class="bi bi-pencil-square me-1"></i>
                        {{ mode === 'CREATE' ? 'Tạo dự án' : 'Cập nhật dự án' }}
                    </div>
                    <button class="btn btn-sm btn-outline-secondary" (click)="cancelForm()" [disabled]="saving">
                        <i class="bi bi-x-lg me-1"></i> Đóng
                    </button>
                </div>

                <div class="card-body">
                    <form [formGroup]="form" (ngSubmit)="submit()">
                        <div class="row g-3">
                            <div class="col-12 col-md-4">
                                <label class="form-label">Mã dự án</label>
                                <input class="form-control" formControlName="maDuAn" [readonly]="mode==='EDIT'" />
                                <div class="invalid-feedback d-block"
                                    *ngIf="form.get('maDuAn')?.touched && form.get('maDuAn')?.invalid">
                                    Mã dự án là bắt buộc
                                </div>
                            </div>

                            <div class="col-12 col-md-8">
                                <label class="form-label">Tên dự án</label>
                                <input class="form-control" formControlName="tenDuAn" />
                                <div class="invalid-feedback d-block"
                                    *ngIf="form.get('tenDuAn')?.touched && form.get('tenDuAn')?.invalid">
                                    Tên dự án là bắt buộc
                                </div>
                            </div>

                            <div class="col-12">
                                <label class="form-label">Mô tả</label>
                                <textarea class="form-control" rows="3" formControlName="moTa"></textarea>
                            </div>

                            <div class="col-12 col-md-4">
                                <label class="form-label">Ngân sách</label>
                                <input class="form-control" type="number" min="0" formControlName="nganSach" />
                            </div>

                            <div class="col-12 col-md-4">
                                <label class="form-label">Ngày bắt đầu</label>
                                <input class="form-control" type="date" formControlName="ngayBatDau" />
                            </div>

                            <div class="col-12 col-md-4">
                                <label class="form-label">Ngày kết thúc</label>
                                <input class="form-control" type="date" formControlName="ngayKetThuc" />
                            </div>

                            <div class="col-12 col-md-4">
                                <label class="form-label">NV phụ trách (ID)</label>
                                <input class="form-control" type="number" min="1" formControlName="nvPhuTrachId" />
                                <div class="form-text">Tạm nhập ID vì BE chưa có API tìm nhân viên.</div>
                            </div>

                            <div class="col-12 d-flex flex-wrap gap-2">
                                <button class="btn btn-primary" type="submit" [disabled]="saving">
                                    <span *ngIf="saving" class="spinner-border spinner-border-sm me-2"></span>
                                    Lưu
                                </button>
                                <button class="btn btn-outline-secondary" type="button" (click)="cancelForm()"
                                    [disabled]="saving">
                                    Hủy
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- RIGHT: DETAIL -->
        <div class="col-12 col-lg-5">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-0 d-flex align-items-center justify-content-between">
                    <div class="fw-semibold">
                        <i class="bi bi-info-circle me-1"></i> Chi tiết
                    </div>

                    <div class="d-flex gap-2">
                        <button class="btn btn-sm btn-outline-primary" (click)="startEditFromSelected()"
                            [disabled]="selectedId<=0 || detailLoading || saving">
                            <i class="bi bi-pencil"></i>
                        </button>
                    </div>
                </div>

                <div class="card-body">
                    <div *ngIf="selectedId<=0" class="text-muted text-center py-4">
                        Chọn 1 dự án bên trái để xem chi tiết
                    </div>

                    <!-- DETAIL SKELETON -->
                    <div *ngIf="detailLoading" class="placeholder-glow">
                        <div class="placeholder col-12 mb-2"></div>
                        <div class="placeholder col-9 mb-2"></div>
                        <div class="placeholder col-10 mb-2"></div>
                        <div class="placeholder col-12 mb-2" style="height: 80px;"></div>
                        <div class="placeholder col-8 mb-2"></div>
                    </div>

                    <div *ngIf="!detailLoading && selectedId>0">
                        <div class="d-flex align-items-start justify-content-between gap-2">
                            <div>
                                <div class="fw-semibold fs-5">{{ selected.tenDuAn }}</div>
                                <div class="text-muted">{{ selected.maDuAn }}</div>
                            </div>
                            <span class="badge" [ngClass]="badgeClass(selected.trangThaiDuAn)">{{ selected.trangThaiDuAn
                                }}</span>
                        </div>

                        <hr />

                        <div class="row g-2 small">
                            <div class="col-6 text-muted">Phụ trách</div>
                            <div class="col-6 text-end fw-semibold">{{ selected.tenNvPhuTrach || '—' }}</div>

                            <div class="col-6 text-muted">Ngân sách</div>
                            <div class="col-6 text-end fw-semibold">
                                {{ selected.nganSach !== null ? (selected.nganSach | number) : '—' }}
                            </div>

                            <div class="col-6 text-muted">Bắt đầu</div>
                            <div class="col-6 text-end fw-semibold">{{ selected.ngayBatDau ? (selected.ngayBatDau |
                                date:'dd/MM/yyyy') : '—' }}</div>

                            <div class="col-6 text-muted">Kết thúc</div>
                            <div class="col-6 text-end fw-semibold">{{ selected.ngayKetThuc ? (selected.ngayKetThuc |
                                date:'dd/MM/yyyy') : '—' }}</div>

                            <div class="col-6 text-muted">Gửi duyệt</div>
                            <div class="col-6 text-end fw-semibold">{{ selected.ngayGuiDuyet ? (selected.ngayGuiDuyet |
                                date:'dd/MM/yyyy HH:mm') : '—' }}</div>

                            <div class="col-6 text-muted">Duyệt</div>
                            <div class="col-6 text-end fw-semibold">{{ selected.ngayDuyet ? (selected.ngayDuyet |
                                date:'dd/MM/yyyy HH:mm') : '—' }}</div>
                        </div>

                        <div class="mt-3">
                            <div class="text-muted small mb-1">Mô tả</div>
                            <div class="p-2 bg-light rounded">
                                {{ selected.moTa || '—' }}
                            </div>
                        </div>

                        <div *ngIf="selected.lyDoTuChoi" class="alert alert-danger mt-3 mb-0">
                            <div class="fw-semibold mb-1"><i class="bi bi-x-circle me-1"></i>Lý do từ chối</div>
                            <div>{{ selected.lyDoTuChoi }}</div>
                        </div>

                        <!-- MEMBERS -->
                        <div class="mt-3">
                            <div class="d-flex align-items-center justify-content-between">
                                <div class="fw-semibold"><i class="bi bi-people me-1"></i>Thành viên</div>
                            </div>

                            <div class="mt-2 p-2 border rounded">
                                <form class="row g-2" [formGroup]="memberForm" (ngSubmit)="addMember()">
                                    <div class="col-5">
                                        <input class="form-control" type="number" min="1" placeholder="NV ID"
                                            formControlName="nvHoSoId" />
                                    </div>
                                    <div class="col-7">
                                        <input class="form-control" placeholder="Vai trò trong dự án"
                                            formControlName="vaiTroTrongDuAn" />
                                    </div>
                                    <div class="col-12 d-flex gap-2">
                                        <button class="btn btn-sm btn-primary" type="submit" [disabled]="saving">
                                            <span *ngIf="saving" class="spinner-border spinner-border-sm me-2"></span>
                                            Thêm
                                        </button>
                                        <button class="btn btn-sm btn-outline-dark" type="button" (click)="guiDuyet()"
                                            [disabled]="!canGuiDuyet() || saving">
                                            <i class="bi bi-send me-1"></i>Gửi duyệt
                                        </button>
                                    </div>
                                </form>

                                <div class="mt-3" *ngIf="selected.thanhViens.length === 0">
                                    <div class="text-muted text-center py-2">Chưa có thành viên</div>
                                </div>

                                <div class="mt-3" *ngFor="let m of selected.thanhViens"
                                    (mouseenter)="patchRole(m.vaiTroTrongDuAn)">
                                    <div
                                        class="member-row d-flex align-items-center justify-content-between gap-2 p-2 rounded">
                                        <div class="min-w-0">
                                            <div class="fw-semibold text-truncate">{{ m.hoTen }}</div>
                                            <div class="small text-muted text-truncate">NV ID: {{ m.nvHoSoId }} • {{
                                                m.vaiTroTrongDuAn }}</div>
                                        </div>

                                        <div class="d-flex align-items-center gap-2">
                                            <div class="d-none d-md-flex">
                                                <input class="form-control form-control-sm role-input"
                                                    [formGroup]="roleForm" formControlName="vaiTroTrongDuAn" />
                                            </div>
                                            <button class="btn btn-sm btn-outline-primary"
                                                (click)="updateMemberRole(m.nvHoSoId)" [disabled]="saving">
                                                <i class="bi bi-save"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-danger"
                                                (click)="removeMember(m.nvHoSoId)" [disabled]="saving">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- LOGS -->
                        <div class="mt-3">
                            <div class="fw-semibold"><i class="bi bi-clock-history me-1"></i>Nhật ký trạng thái</div>

                            <div class="mt-2" *ngIf="selected.nhatKyTrangThais.length === 0">
                                <div class="text-muted text-center py-2">Chưa có nhật ký</div>
                            </div>

                            <div class="timeline mt-2" *ngIf="selected.nhatKyTrangThais.length > 0">
                                <div class="timeline-item" *ngFor="let l of selected.nhatKyTrangThais">
                                    <div class="dot"></div>
                                    <div class="content">
                                        <div class="fw-semibold">
                                            {{ l.trangThaiCu }} → {{ l.trangThaiMoi }}
                                        </div>
                                        <div class="small text-muted">
                                            {{ l.thoiGian | date:'dd/MM/yyyy HH:mm' }} • {{ l.nguoiThucHien }}
                                        </div>
                                        <div class="small">{{ l.ghiChu || '—' }}</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>

            <!-- INSIGHT CARD -->
            <div class="card border-0 shadow-sm mt-3">
                <div class="card-body">
                    <div class="fw-semibold mb-1"><i class="bi bi-lightbulb me-1"></i>Insight</div>
                    <div class="text-muted small">
                        Ưu tiên gửi duyệt các dự án hoàn chỉnh (có phụ trách + thành viên + timeline) để giám đốc duyệt
                        nhanh.
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>